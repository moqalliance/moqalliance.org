---
// Newsletter signup form. POSTs to /api/subscribe which writes to D1.
// After submission the endpoint redirects back with ?subscribed=ok|invalid|error;
// the inline script translates that into an in-page status message.
---

<p class="subscribe-label">Subscribe to MoQ Alliance updates:</p>
<form class="subscribe" action="/api/subscribe" method="post">
	<label class="sr-only" for="email">Email</label>
	<input
		id="email"
		type="email"
		name="email"
		placeholder="you@example.com"
		required
		autocomplete="email"
	/>
	<button type="submit">Subscribe</button>
</form>
<p class="subscribe-status" data-status hidden></p>

<script is:inline>
	(() => {
		const params = new URLSearchParams(window.location.search);
		const state = params.get("subscribed");
		if (!state) return;
		const el = document.querySelector("[data-status]");
		if (!el) return;
		const messages = {
			ok: "Thanks! You're on the list.",
			invalid: "That doesn't look like a valid email. Try again.",
			error: "Something went wrong saving that. Please try again later.",
		};
		el.textContent = messages[state] || "";
		el.hidden = !el.textContent;
		// Drop the query param so a reload doesn't re-show the message.
		const url = new URL(window.location.href);
		url.searchParams.delete("subscribed");
		window.history.replaceState({}, "", url.toString());
	})();
</script>
