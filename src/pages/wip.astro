---
import Layout from "../layouts/Layout.astro";
import events from "../data/events.json";
import resources from "../data/resources.json";
---

<Layout title="MoQ Alliance — Draft" noindex={true} og={false}>
	<header>
		<img
			class="logo"
			src="/logo.svg"
			alt="MoQ Alliance"
			width="44"
			height="44"
		/>
		<h1>MoQ Alliance — Draft</h1>
		<p class="note">
			This page is a staging area for future content. It is not linked
			from the main site and is excluded from search engines.{" "}
			<a href="/">Back to moqalliance.org</a>.
		</p>
	</header>

	<section>
		<h2>Events</h2>
		<dl>
			{
				events.map((e) => (
					<>
						<dt>
							<a href={e.url}>{e.title}</a>
						</dt>
						<dd>{e.description}</dd>
					</>
				))
			}
		</dl>
	</section>

	<section>
		<h2>Resources</h2>
		<dl>
			{
				resources.map((r) => (
					<>
						<dt>
							<a href={r.url}>{r.title}</a>
						</dt>
						<dd>{r.description}</dd>
					</>
				))
			}
		</dl>
	</section>

	<section>
		<h2>Become a member</h2>
		<p>
			Interested in joining the MoQ Alliance as an organization? Email{" "}
			<a href="mailto:hello@moqalliance.org">hello@moqalliance.org</a>.
		</p>
	</section>
</Layout>
